# Server
NODE_ENV=development
PORT=3001
API_PREFIX=api/v1

# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tms?schema=public"

# JWT (configure before auth module implementation)
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:3000

# Auth
BCRYPT_ROUNDS=12
OTP_LENGTH=6
OTP_EXPIRES_MINUTES=10
OTP_MAX_ATTEMPTS=5
REFRESH_TOKEN_COOKIE_NAME=tms_refresh_token
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
COOKIE_PATH=/

# Seed (development only)
SEED_ADMIN_EMAIL=admin@tms.local
SEED_ADMIN_PASSWORD=Admin@123456

# OTP / SMTP (future — OTP logged to console in development)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
