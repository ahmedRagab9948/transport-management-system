// TMS — Authentication & authorization foundation
// See ai-docs/database-schema.md and prisma/README.md

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Sector Management enums
// ---------------------------------------------------------------------------

enum RecordStatus {
  ACTIVE
  INACTIVE
}

enum AssignmentReason {
  ASSIGNMENT
  TRANSFER
  UNASSIGNMENT
}

// ---------------------------------------------------------------------------
// Roles & permissions (RBAC)
// ---------------------------------------------------------------------------

// ---------------------------------------------------------------------------
// Clients
// ---------------------------------------------------------------------------

enum ClientStatus {
  ACTIVE
  INACTIVE
}

model Client {
  id            String       @id @default(uuid()) @db.Uuid
  companyName   String       @map("company_name") @db.VarChar(255)
  contactPerson String       @map("contact_person") @db.VarChar(255)
  email         String?      @db.VarChar(255)
  phone         String?      @db.VarChar(50)
  address       String?      @db.Text
  taxNumber     String?      @map("tax_number") @db.VarChar(100)
  notes         String?      @db.Text
  status        ClientStatus @default(ACTIVE)
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  deletedAt     DateTime?    @map("deleted_at")

  trips     Trip[]
  contracts Contract[]

  @@index([companyName])
  @@index([email])
  @@index([status])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("clients")
}

// ---------------------------------------------------------------------------
// Contracts
// ---------------------------------------------------------------------------

enum ContractType {
  PER_TRIP
  MONTHLY
}

enum ContractStatus {
  DRAFT
  ACTIVE
  EXPIRED
  TERMINATED
}

model Contract {
  id                String         @id @default(uuid()) @db.Uuid
  contractNumber    String         @map("contract_number") @db.VarChar(100)
  clientId          String         @map("client_id") @db.Uuid
  title             String         @db.VarChar(255)
  description       String?        @db.Text
  fromLocation      String?        @map("from_location") @db.VarChar(500)
  toLocation        String?        @map("to_location") @db.VarChar(500)
  price             Decimal?       @db.Decimal(12, 2)
  currency          String         @default("EGP") @db.VarChar(10)
  contractType      ContractType   @default(PER_TRIP) @map("contract_type")
  startDate         DateTime?      @map("start_date")
  endDate           DateTime?      @map("end_date")
  status            ContractStatus @default(DRAFT)
  assignedVehicleId String?        @map("assigned_vehicle_id") @db.Uuid
  assignedDriverId  String?        @map("assigned_driver_id") @db.Uuid
  notes             String?        @db.Text
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")
  deletedAt         DateTime?      @map("deleted_at")

  client          Client   @relation(fields: [clientId], references: [id], onDelete: Restrict)
  assignedVehicle Vehicle? @relation("AssignedVehicle", fields: [assignedVehicleId], references: [id], onDelete: SetNull)
  assignedDriver  Driver?  @relation("ContractDriver", fields: [assignedDriverId], references: [id], onDelete: SetNull)
  trips           Trip[]

  @@unique([contractNumber])
  @@index([clientId])
  @@index([status])
  @@index([startDate])
  @@index([endDate])
  @@index([assignedVehicleId])
  @@index([assignedDriverId])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("contracts")
}

// ---------------------------------------------------------------------------
// Sectors & Sub-sectors
// ---------------------------------------------------------------------------

model Sector {
  id          String       @id @default(uuid()) @db.Uuid
  name        String       @unique @db.VarChar(255)
  code        String       @unique @db.VarChar(50)
  description String?      @db.Text
  status      RecordStatus @default(ACTIVE)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  subSectors SubSector[]
  fromTrips  Trip[]      @relation("TripFromSector")
  toTrips    Trip[]      @relation("TripToSector")

  @@index([status])
  @@index([createdAt])
  @@map("sectors")
}

model SubSector {
  id          String       @id @default(uuid()) @db.Uuid
  sectorId    String       @map("sector_id") @db.Uuid
  name        String       @db.VarChar(255)
  code        String       @db.VarChar(50)
  description String?      @db.Text
  status      RecordStatus @default(ACTIVE)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  sector              Sector                     @relation(fields: [sectorId], references: [id], onDelete: Restrict)
  vehicleAssignments  VehicleAssignment[]
  vehicleHistory      VehicleAssignmentHistory[]
  transferFromHistory VehicleAssignmentHistory[] @relation("TransferFrom")

  @@unique([sectorId, name])
  @@unique([sectorId, code])
  @@index([sectorId])
  @@index([status])
  @@map("sub_sectors")
}

// ---------------------------------------------------------------------------
// Vehicle Assignments
// ---------------------------------------------------------------------------

model VehicleAssignment {
  id           String    @id @default(uuid()) @db.Uuid
  vehicleId    String    @map("vehicle_id") @db.Uuid
  subSectorId  String    @map("sub_sector_id") @db.Uuid
  assignedAt   DateTime  @default(now()) @map("assigned_at")
  unassignedAt DateTime? @map("unassigned_at")
  notes        String?   @db.Text

  vehicle   Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  subSector SubSector @relation(fields: [subSectorId], references: [id], onDelete: Restrict)

  @@unique([vehicleId], name: "idx_one_active_assignment", where: raw("unassigned_at IS NULL"))
  @@index([vehicleId])
  @@index([subSectorId])
  @@index([assignedAt])
  @@index([unassignedAt])
  @@index([subSectorId, unassignedAt])
  @@map("vehicle_assignments")
}

model VehicleAssignmentHistory {
  id                         String           @id @default(uuid()) @db.Uuid
  vehicleId                  String           @map("vehicle_id") @db.Uuid
  subSectorId                String?          @map("sub_sector_id") @db.Uuid
  assignedAt                 DateTime         @map("assigned_at")
  unassignedAt               DateTime?        @map("unassigned_at")
  transferredFromSubSectorId String?          @map("transferred_from_sub_sector_id") @db.Uuid
  reason                     AssignmentReason
  notes                      String?          @db.Text
  changedById                String?          @map("changed_by") @db.Uuid
  createdAt                  DateTime         @default(now()) @map("created_at")

  vehicle                  Vehicle    @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  subSector                SubSector? @relation(fields: [subSectorId], references: [id], onDelete: SetNull)
  transferredFromSubSector SubSector? @relation("TransferFrom", fields: [transferredFromSubSectorId], references: [id], onDelete: SetNull)
  changedBy                User?      @relation(fields: [changedById], references: [id], onDelete: SetNull)

  @@index([vehicleId])
  @@index([subSectorId])
  @@index([reason])
  @@index([createdAt])
  @@map("vehicle_assignment_histories")
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique @db.VarChar(100)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users           User[]
  rolePermissions RolePermission[]

  @@index([createdAt])
  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique @db.VarChar(100)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String   @map("role_id") @db.Uuid
  permissionId String   @map("permission_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

// ---------------------------------------------------------------------------
// Users
// ---------------------------------------------------------------------------

model User {
  id                String    @id @default(uuid()) @db.Uuid
  fullName          String    @map("full_name") @db.VarChar(255)
  email             String    @unique @db.VarChar(255)
  passwordHash      String    @map("password_hash") @db.VarChar(255)
  phone             String?   @db.VarChar(50)
  roleId            String    @map("role_id") @db.Uuid
  isActive          Boolean   @default(true) @map("is_active")
  otpEnabled        Boolean   @default(true) @map("otp_enabled")
  preferredLanguage String    @default("ar") @map("preferred_language") @db.VarChar(10)
  timezone          String?   @db.VarChar(100)
  avatar            String?   @db.VarChar(500)
  mfaEnabled          Boolean   @default(false) @map("mfa_enabled")
  mfaVerifiedAt       DateTime? @map("mfa_verified_at")
  profileUpdatedAt    DateTime? @map("profile_updated_at")
  passwordChangedAt   DateTime? @map("password_changed_at")
  lastLoginAt         DateTime? @map("last_login_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  deletedAt           DateTime? @map("deleted_at")

  role                       Role                       @relation(fields: [roleId], references: [id], onDelete: Restrict)
  otpVerifications           OtpVerification[]
  refreshTokens              RefreshToken[]
  auditLogs                  AuditLog[]
  notifications              Notification[]
  vehicleStatusChanges       VehicleStatusHistory[]
  driverStatusChanges        DriverStatusHistory[]
  tripStatusHistories        TripStatusHistory[]
  createdTrips               Trip[]
  vehicleAssignmentHistories VehicleAssignmentHistory[]

  @@index([roleId])
  @@index([isActive])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("users")
}

// ---------------------------------------------------------------------------
// Vehicles
// ---------------------------------------------------------------------------

enum VehicleType {
  TRAILER
  JUMBO
}

enum VehicleStatus {
  ACTIVE
  IN_TRIP
  IN_MAINTENANCE
  OUT_OF_SERVICE
}

enum VehiclePlateRole {
  TRUCK_HEAD
  TRAILER_UNIT
  JUMBO
}

model Vehicle {
  id              String        @id @default(uuid()) @db.Uuid
  vehicleCode     String        @map("vehicle_code") @db.VarChar(100)
  type            VehicleType
  status          VehicleStatus @default(ACTIVE)
  currentDriverId String?       @map("current_driver_id") @db.Uuid
  manufacturer    String?       @db.VarChar(100)
  model           String?       @db.VarChar(100)
  productionYear  Int?          @map("production_year")
  capacityKg      Int?          @map("capacity_kg")
  notes           String?       @db.Text
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  deletedAt       DateTime?     @map("deleted_at")

  plates              VehiclePlate[]
  statusHistories     VehicleStatusHistory[]
  trips               Trip[]
  vehicleAssignments  VehicleAssignment[]
  assignmentHistories VehicleAssignmentHistory[]
  monthlyContracts    Contract[]                 @relation("AssignedVehicle")
  assignedDriverId    String?                    @map("assigned_driver_id") @db.Uuid
  assignedDriver      Driver?                    @relation(fields: [assignedDriverId], references: [id], onDelete: SetNull)

  @@unique([vehicleCode], name: "vehicles_vehicle_code_key", where: raw("deleted_at IS NULL"))
  @@index([type])
  @@index([status])
  @@index([currentDriverId])
  @@index([assignedDriverId])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("vehicles")
}

model VehiclePlate {
  id          String           @id @default(uuid()) @db.Uuid
  vehicleId   String           @map("vehicle_id") @db.Uuid
  role        VehiclePlateRole
  plateNumber String           @map("plate_number") @db.VarChar(50)
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  deletedAt   DateTime?        @map("deleted_at")

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@unique([vehicleId, role])
  @@index([vehicleId])
  @@index([plateNumber])
  @@index([deletedAt])
  @@map("vehicle_plates")
}

model VehicleStatusHistory {
  id          String         @id @default(uuid()) @db.Uuid
  vehicleId   String         @map("vehicle_id") @db.Uuid
  oldStatus   VehicleStatus? @map("old_status")
  newStatus   VehicleStatus  @map("new_status")
  changedById String?        @map("changed_by") @db.Uuid
  changedAt   DateTime       @default(now()) @map("changed_at")
  notes       String?        @db.Text

  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  changedBy User?   @relation(fields: [changedById], references: [id], onDelete: SetNull)

  @@index([vehicleId])
  @@index([newStatus])
  @@index([changedById])
  @@index([changedAt])
  @@index([vehicleId, changedAt])
  @@map("vehicle_status_histories")
}

// ---------------------------------------------------------------------------
// Drivers
// ---------------------------------------------------------------------------

enum DriverStatus {
  ACTIVE
  IN_TRIP
  INACTIVE
  SUSPENDED
}

model Driver {
  id               String       @id @default(uuid()) @db.Uuid
  driverCode       String       @map("driver_code") @db.VarChar(100)
  fullName         String       @map("full_name") @db.VarChar(255)
  phone            String       @db.VarChar(50)
  nationalId       String       @map("national_id") @db.VarChar(100)
  licenseNumber    String       @map("license_number") @db.VarChar(100)
  licenseExpiry    DateTime     @map("license_expiry")
  status           DriverStatus @default(ACTIVE)
  currentVehicleId String?      @map("current_vehicle_id") @db.Uuid
  notes            String?      @db.Text
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")
  deletedAt        DateTime?    @map("deleted_at")

  statusHistories     DriverStatusHistory[]
  trips               Trip[]
  assignedVehicles    Vehicle[]
  contractAssignments Contract[]            @relation("ContractDriver")

  @@unique([driverCode], name: "drivers_driver_code_key", where: raw("deleted_at IS NULL"))
  @@index([fullName])
  @@index([phone])
  @@index([nationalId])
  @@index([status])
  @@index([licenseNumber])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("drivers")
}

model DriverStatusHistory {
  id          String        @id @default(uuid()) @db.Uuid
  driverId    String        @map("driver_id") @db.Uuid
  oldStatus   DriverStatus? @map("old_status")
  newStatus   DriverStatus  @map("new_status")
  changedById String?       @map("changed_by") @db.Uuid
  changedAt   DateTime      @default(now()) @map("changed_at")
  notes       String?       @db.Text

  driver    Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)
  changedBy User?  @relation(fields: [changedById], references: [id], onDelete: SetNull)

  @@index([driverId])
  @@index([newStatus])
  @@index([changedById])
  @@index([changedAt])
  @@index([driverId, changedAt])
  @@map("driver_status_histories")
}

// ---------------------------------------------------------------------------
// Trips
// ---------------------------------------------------------------------------

enum TripStatus {
  DRAFT
  PENDING
  ASSIGNED
  DRIVER_CONFIRMED
  LOADING
  ON_ROUTE
  WAITING
  UNLOADING
  COMPLETED
  CANCELLED
}

model Trip {
  id               String     @id @default(uuid()) @db.Uuid
  tripNumber       String     @map("trip_number") @db.VarChar(100)
  clientId         String?    @map("client_id") @db.Uuid
  contractId       String?    @map("contract_id") @db.Uuid
  vehicleId        String     @map("vehicle_id") @db.Uuid
  driverId         String     @map("driver_id") @db.Uuid
  status           TripStatus @default(DRAFT)
  fromLocation     String     @map("from_location") @db.VarChar(500)
  toLocation       String     @map("to_location") @db.VarChar(500)
  cargoDescription String?    @map("cargo_description") @db.Text
  startDate        DateTime?  @map("start_date")
  endDate          DateTime?  @map("end_date")
  actualStartDate  DateTime?  @map("actual_start_date")
  actualEndDate    DateTime?  @map("actual_end_date")
  waitingStartedAt DateTime?  @map("waiting_started_at")
  waitingEndedAt   DateTime?  @map("waiting_ended_at")
  price            Decimal?   @db.Decimal(12, 2)
  notes            String?    @db.Text
  fromSectorId     String?    @map("from_sector_id") @db.Uuid
  toSectorId       String?    @map("to_sector_id") @db.Uuid
  createdById      String     @map("created_by") @db.Uuid
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")
  deletedAt        DateTime?  @map("deleted_at")

  client          Client?             @relation(fields: [clientId], references: [id], onDelete: SetNull)
  contract        Contract?           @relation(fields: [contractId], references: [id], onDelete: SetNull)
  vehicle         Vehicle             @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  driver          Driver              @relation(fields: [driverId], references: [id], onDelete: Restrict)
  createdBy       User                @relation(fields: [createdById], references: [id], onDelete: Restrict)
  fromSector      Sector?             @relation("TripFromSector", fields: [fromSectorId], references: [id], onDelete: SetNull)
  toSector        Sector?             @relation("TripToSector", fields: [toSectorId], references: [id], onDelete: SetNull)
  statusHistories TripStatusHistory[]

  @@unique([vehicleId], name: "idx_trip_single_active_vehicle", where: raw("status IN ('ASSIGNED', 'DRIVER_CONFIRMED', 'LOADING', 'ON_ROUTE', 'WAITING', 'UNLOADING') AND deleted_at IS NULL"))
  @@unique([driverId], name: "idx_trip_single_active_driver", where: raw("status IN ('ASSIGNED', 'DRIVER_CONFIRMED', 'LOADING', 'ON_ROUTE', 'WAITING', 'UNLOADING') AND deleted_at IS NULL"))
  @@unique([tripNumber], name: "trips_trip_number_key", where: raw("deleted_at IS NULL"))
  @@index([clientId])
  @@index([contractId])
  @@index([vehicleId])
  @@index([driverId])
  @@index([status])
  @@index([startDate])
  @@index([endDate])
  @@index([startDate, endDate])
  @@index([actualStartDate, actualEndDate])
  @@index([fromSectorId])
  @@index([toSectorId])
  @@index([createdById])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("trips")
}

model TripStatusHistory {
  id          String      @id @default(uuid()) @db.Uuid
  tripId      String      @map("trip_id") @db.Uuid
  oldStatus   TripStatus? @map("old_status")
  newStatus   TripStatus  @map("new_status")
  changedById String?     @map("changed_by") @db.Uuid
  changedAt   DateTime    @default(now()) @map("changed_at")
  reasonCode  String?     @map("reason_code") @db.VarChar(50)
  notes       String?     @db.Text

  trip      Trip  @relation(fields: [tripId], references: [id], onDelete: Cascade)
  changedBy User? @relation(fields: [changedById], references: [id], onDelete: SetNull)

  @@index([tripId])
  @@index([newStatus])
  @@index([reasonCode])
  @@index([changedById])
  @@index([changedAt])
  @@index([tripId, changedAt])
  @@map("trip_status_histories")
}

// ---------------------------------------------------------------------------
// OTP (login verification — business rule: OTP required during login)
// ---------------------------------------------------------------------------

model OtpVerification {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  otpCode    String    @map("otp_code") @db.VarChar(255)
  expiresAt  DateTime  @map("expires_at")
  verifiedAt DateTime? @map("verified_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([createdAt])
  @@map("otp_verifications")
}

// ---------------------------------------------------------------------------
// Refresh tokens (rotation + revocation)
// ---------------------------------------------------------------------------

model RefreshToken {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  tokenHash  String    @unique @map("token_hash") @db.VarChar(255)
  familyId   String    @map("family_id") @db.Uuid
  expiresAt  DateTime  @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  replacedBy String?   @map("replaced_by") @db.Uuid
  userAgent  String?   @map("user_agent") @db.Text
  ipAddress  String?   @map("ip_address") @db.VarChar(45)
  createdAt  DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([familyId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@map("refresh_tokens")
}

// ---------------------------------------------------------------------------
// System Settings (key/value, grouped)
// ---------------------------------------------------------------------------

model SystemSetting {
  id        String   @id @default(uuid()) @db.Uuid
  key       String   @unique @db.VarChar(200)
  value     String?  @db.Text
  group     String   @db.VarChar(100)
  type      String   @default("string") @db.VarChar(50)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([group])
  @@index([group, key])
  @@map("system_settings")
}

// ---------------------------------------------------------------------------
// Audit log (immutable; no soft delete)
// ---------------------------------------------------------------------------

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  action     String   @db.VarChar(100)
  entityType String   @map("entity_type") @db.VarChar(100)
  entityId   String?  @map("entity_id") @db.Uuid
  oldValues  Json?    @map("old_values")
  newValues  Json?    @map("new_values")
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  userAgent  String?  @map("user_agent") @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([entityType, entityId, createdAt])
  @@index([createdAt])
  @@map("audit_logs")
}

// ---------------------------------------------------------------------------
// Notifications (in-app)
// ---------------------------------------------------------------------------

enum NotificationType {
  TRIP_CREATED
  TRIP_ASSIGNED
  TRIP_STATUS_CHANGED
  TRIP_COMPLETED
  TRIP_CANCELLED
  VEHICLE_MAINTENANCE
  VEHICLE_OUT_OF_SERVICE
  DRIVER_SUSPENDED
  DRIVER_INACTIVE
  CONTRACT_EXPIRING
  CONTRACT_COMPLETED
}

model Notification {
  id         String           @id @default(uuid()) @db.Uuid
  userId     String           @map("user_id") @db.Uuid
  title      String           @db.VarChar(255)
  message    String?          @db.Text
  type       NotificationType @default(TRIP_CREATED)
  entityType String?          @map("entity_type") @db.VarChar(100)
  entityId   String?          @map("entity_id") @db.Uuid
  readAt     DateTime?        @map("read_at")
  createdAt  DateTime         @default(now()) @map("created_at")
  archivedAt DateTime?        @map("archived_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, createdAt])
  @@index([archivedAt])
  @@map("notifications")
}
